#root {
    width: grow;
    height: grow;
    flex-direction: column;
    background-color: #09090C;
}

#toolbar {
    width: 100%;
    height: 44px;
    flex-direction: row;
    align-items: center;
    background-color: #0D0D12;
    border-color: #1E1E2A;
    border-width: 1px;
    padding: 0px 8px;
    gap: 0px;
}

#toolbar-left {
    flex-direction: row;
    align-items: center;
    gap: 2px;
    width: grow;
}

#toolbar-center {
    flex-direction: row;
    align-items: center;
    gap: 3px;
}

#toolbar-right {
    flex-direction: row;
    align-items: center;
    justify-content: end;
    width: grow;
    padding: 0px 4px;
}

#engine-logo {
    font-family: bold;
    font-size: 20px;
    color: #4A8FD4;
    padding: 0px 12px 0px 2px;
}

.toolbar-sep {
    width: 1px;
    height: 18px;
    background-color: #2A2A3A;
    margin: 0px 6px;
}

.menu-btn {
    font-family: regular;
    font-size: 15px;
    color: #5A7A9A;
    padding: 4px 9px;
    border-radius: 4px;
    align-items: center;
    justify-content: center;
    transition: 120ms ease-out;
}

.menu-btn:hover {
    background-color: #181820;
    color: #7ABCE8;
}

.menu-btn:pressed {
    background-color: #111118;
    color: #C0E0F8;
}

.run-btn {
    font-family: medium;
    font-size: 18px;
    color: #5A7A9A;
    padding: 4px 18px;
    border-radius: 5px;
    border-width: 1px;
    border-color: #2A2A3A;
    align-items: center;
    justify-content: center;
    transition: 120ms ease-out;
}

.run-btn:hover {
    background-color: #181820;
    border-color: #4A8FD4;
    color: #7ABCE8;
}

.run-stop {
    color: #C04A4A;
    border-color: #3A2020;
}

.run-stop:hover {
    background-color: #1C1010;
    border-color: #703030;
    color: #E08080;
}

#fps-counter {
    font-family: thin;
    font-size: 18px;
    color: #2A3A50;
}


#workspace {
    width: 100%;
    height: grow;
    flex-direction: row;
}


.panel-header {
    flex-direction: row;
    align-items: center;
    width: 100%;
    height: 30px;
    padding: 0px 8px;
    background-color: #0D0D12;
    border-color: #1E1E2A;
    border-width: 1px;
    gap: 6px;
}

.panel-title {
    font-family: bold;
    font-size: 13px;
    color: #5A7A9A;
    width: grow;
}

.icon-btn {
    font-family: regular;
    font-size: 16px;
    color: #5A7A9A;
    width: 18px;
    height: 18px;
    border-radius: 3px;
    align-items: center;
    justify-content: center;
    transition: 100ms ease-out;
}

.icon-btn:hover {
    background-color: #181820;
    color: #4A8FD4;
}


#panel-hierarchy {
    width: 200px;
    height: 100%;
    flex-direction: column;
    background-color: #0D0D12;
    border-color: #1E1E2A;
    border-width: 1px;
    overflow: hidden;
}

#scene-tree {
    flex-direction: column;
    width: 100%;
    padding: 4px 0px;
    gap: 0px;
}

.tree-item {
    font-family: regular;
    font-size: 15px;
    color: #5A7A9A;
    width: 100%;
    height: 26px;
    padding: 0px 10px;
    align-items: center;
    justify-content: start;
    border-radius: 0px;
    transition: 80ms linear;
}

.tree-item:hover {
    background-color: #181820;
    color: #7ABCE8;
}

.tree-item:pressed {
    background-color: #1E1E2A;
    color: #C0E0F8;
}

.tree-selected {
    background-color: #1A1E2C;
    color: #7ABCE8;
}

.tree-l1 {
    padding: 0px 0px 0px 22px;
    color: #405870;
}

.tree-l2 {
    padding: 0px 0px 0px 36px;
    color: #2A3A50;
    font-size: 18px;
}


#center-col {
    width: grow;
    height: 100%;
    flex-direction: column;
}

#viewport-bar {
    width: 100%;
    height: 34px;
    flex-direction: row;
    align-items: center;
    background-color: #0D0D12;
    border-color: #1E1E2A;
    border-width: 1px;
    padding: 0px 4px;
    gap: 2px;
}

.vp-tab {
    font-family: regular;
    font-size: 18px;
    color: #405870;
    padding: 3px 12px;
    height: 26px;
    border-radius: 4px;
    align-items: center;
    justify-content: center;
    transition: 100ms linear;
}

.vp-tab:hover {
    background-color: #181820;
    color: #5A7A9A;
}

.vp-tab-active {
    background-color: #1A1E2C;
    color: #7ABCE8;
    border-width: 1px;
    border-color: #2A2A3A;
}

#vp-bar-spacer {
    width: grow;
}

.vp-mode {
    font-family: regular;
    font-size: 18px;
    color: #2A3A50;
    padding: 3px 12px;
    height: 26px;
    border-radius: 4px;
    align-items: center;
    justify-content: center;
    transition: 100ms linear;
}

.vp-mode:hover {
    background-color: #181820;
    color: #5A7A9A;
}

#viewport {
    width: 100%;
    height: grow;
}


#panel-inspector {
    width: 240px;
    height: 100%;
    flex-direction: column;
    background-color: #0D0D12;
    border-color: #1E1E2A;
    border-width: 1px;
    overflow: hidden;
}

#inspector-scroll {
    flex-direction: column;
    width: 100%;
    padding: 8px;
    gap: 6px;
}

#obj-header {
    flex-direction: row;
    align-items: center;
    width: 100%;
    gap: 8px;
    padding: 4px 0px;
}

#obj-active {
    width: 16px;
    height: 16px;
}

#obj-name-input {
    width: grow;
    height: 30px;
    background-color: #181820;
    border-width: 1px;
    border-color: #2A2A3A;
    border-radius: 5px;
    color: #C0E0F8;
    font-family: regular;
    font-size: 15px;
    transition: 100ms ease-out;
}

#obj-name-input:focus {
    border-color: #4A8FD4;
}

.comp-block {
    flex-direction: column;
    width: 100%;
    background-color: #111118;
    border-radius: 6px;
    border-width: 1px;
    border-color: #1E1E2A;
    padding: 8px;
    gap: 5px;
}

.comp-header {
    flex-direction: row;
    align-items: center;
    width: 100%;
    padding: 0px 0px 4px 0px;
    border-color: #1E1E2A;
    border-width: 1px;
    gap: 6px;
}

.comp-name {
    font-family: bold;
    font-size: 18px;
    color: #4A8FD4;
    width: grow;
}

.prop-xyz {
    flex-direction: row;
    align-items: center;
    width: 100%;
    gap: 3px;
}

.axis-label {
    font-family: bold;
    font-size: 13px;
    color: #405870;
    width: 18px;
}

.xyz-input {
    flex-grow: 1;
    height: 26px;
    background-color: #181820;
    border-width: 1px;
    border-color: #2A2A3A;
    border-radius: 4px;
    color: #7ABCE8;
    font-family: regular;
    font-size: 13px;
    transition: 80ms ease-out;
}

.xyz-input:focus {
    border-color: #4A8FD4;
}

.prop-row {
    flex-direction: row;
    align-items: center;
    width: 100%;
    gap: 8px;
}

.prop-lbl {
    font-family: regular;
    font-size: 18px;
    color: #405870;
    width: 64px;
}

.asset-ref {
    flex-grow: 1;
    height: 26px;
    font-family: regular;
    font-size: 18px;
    color: #4A8FD4;
    background-color: #181820;
    border-width: 1px;
    border-color: #2A2A3A;
    border-radius: 4px;
    align-items: center;
    justify-content: center;
    transition: 80ms ease-out;
}

.asset-ref:hover {
    background-color: #1E1E2A;
    border-color: #5A7A9A;
    color: #7ABCE8;
}

.prop-check {
    width: 16px;
    height: 16px;
}

.prop-slider {
    flex-grow: 1;
    height: 20px;
    color: #4A8FD4;
}

.prop-input {
    flex-grow: 1;
    height: 26px;
    background-color: #181820;
    border-width: 1px;
    border-color: #2A2A3A;
    border-radius: 4px;
    color: #7ABCE8;
    font-family: regular;
    font-size: 18px;
    transition: 80ms ease-out;
}

.prop-input:focus {
    border-color: #4A8FD4;
}


#content-browser {
    width: 100%;
    height: 110px;
    flex-direction: column;
    background-color: #0D0D12;
    border-color: #1E1E2A;
    border-width: 1px;
}

#cb-gap {
    width: grow;
}

#cb-search {
    width: 180px;
    height: 22px;
    background-color: #181820;
    border-width: 1px;
    border-color: #2A2A3A;
    border-radius: 4px;
    color: #7ABCE8;
    font-family: regular;
    font-size: 18px;
    transition: 80ms ease-out;
}

#cb-search:focus {
    border-color: #4A8FD4;
}

#asset-grid {
    flex-direction: row;
    flex-wrap: wrap;
    width: 100%;
    height: grow;
    padding: 6px 8px;
    gap: 6px;
    align-items: center;
}

.asset-folder {
    font-family: regular;
    font-size: 18px;
    color: #5A7A9A;
    height: 52px;
    width: 68px;
    background-color: #111118;
    border-width: 1px;
    border-color: #2A2A3A;
    border-radius: 6px;
    align-items: center;
    justify-content: center;
    transition: 100ms ease-out;
}

.asset-folder:hover {
    background-color: #1A1E2C;
    border-color: #5A7A9A;
    color: #7ABCE8;
}

.asset-folder:pressed {
    background-color: #0D0D12;
    border-color: #4A8FD4;
    color: #C0E0F8;
}


Button {
    align-items: center;
    justify-content: center;
}

Checkbox {
    background-color: #181820;
    border-radius: 4px;
    border-width: 1.5px;
    border-color: #2A2A3A;
    color: #4A8FD4;
    transition: 120ms ease-out;
}

Checkbox:hover {
    background-color: #1E1E2A;
    border-color: #5A7A9A;
}

Checkbox:pressed {
    background-color: #111118;
    border-color: #4A8FD4;
}

Slider {
    color: #4A8FD4;
}


ContextMenu {
    background-color: #111118;
    border-width: 1px;
    border-color: #2A2A3A;
    border-radius: 6px;
    padding: 4px 0px;
    width: 160px;
}

.context-item {
    font-family: regular;
    font-size: 18px;
    color: #4A8FD4;
    width: 100%;
    height: 28px;
    padding: 0px 12px;
    align-items: center;
    justify-content: start;
    border-radius: 0px;
    transition: 80ms ease-out;
}

.context-item:hover {
    background-color: #1A1E2C;
    color: #7ABCE8;
}

.context-item:pressed {
    background-color: #0D0D12;
    color: #C0E0F8;
}