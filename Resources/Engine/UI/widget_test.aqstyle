
#root {
    width: grow;
    height: grow;
    flex-direction: row;
    background-color: #0E0A07;
}

/* ── Sidebar ─────────────────────────────────────────────────────────────── */

#sidebar {
    width: 22%;
    height: 100%;
    background-color: #14100C;
    border-color: #2A1F14;
    border-width: 1px;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 32px 16px;
    gap: 8px;
}

#brand {
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0px 0px 20px 0px;
    gap: 6px;
}

#brand-name {
    font-family: bold;
    font-size: 52px;
    color: #F5DFC0;
}

#sidebar-divider {
    width: 100%;
    height: 1px;
    background-color: #2A1F14;
}

#nav {
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    gap: 10px;
    padding: 12px 0px;
}

.nav-btn {
    font-family: medium;
    font-size: 18px;
    color: #A07850;
    width: grow;
    padding: 10px 14px;
    border-radius: 10px;
    border-width: 2px;
    border-color: #3D2812;
    align-items: center;
    justify-content: center;
    transition: 180ms ease-out;
    gap: 10px;
}

.nav-btn:hover {
    background-color: #1E150E;
    border-color: #3D2812;
    color: #F0C898;
}

.nav-btn:pressed {
    background-color: #160D07;
    border-color: #C8905A;
    color: #F5DFC0;
}

#version-area {
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 20px 0px 0px 0px;
}

#version-label {
    font-family: thin;
    font-size: 13px;
    color: #4A3020;
}

/* ── Main area ───────────────────────────────────────────────────────────── */

#main {
    width: 78%;
    height: 100%;
    background-color: #0E0A07;
    flex-direction: column;
    align-items: center;
    padding: 28px 24px 24px 24px;
    gap: 16px;
}

#main-header {
    flex-direction: row;
    justify-content: start;
    width: 100%;
}

#section-title {
    font-family: bold;
    font-size: 30px;
    color: #F5DFC0;
    width: 100%;
}

/* ── Panel row (widgets left, viewport right) ─────────────────────────────── */

#panel-row {
    flex-direction: row;
    width: 100%;
    height: grow;
    gap: 20px;
    align-items: start;
}

/* ── Widget panel ────────────────────────────────────────────────────────── */

#widget-panel {
    width: 270px;
    flex-direction: column;
    background-color: #14100C;
    border-radius: 12px;
    border-width: 1px;
    border-color: #2A1F14;
    padding: 16px;
    gap: 6px;
}

.section-label {
    font-family: bold;
    font-size: 10px;
    color: #5A3E28;
    padding: 10px 0px 2px 0px;
    width: 100%;
}

.widget-row {
    flex-direction: row;
    align-items: center;
    gap: 10px;
    width: 100%;
}

.widget-label {
    font-family: regular;
    font-size: 14px;
    color: #A07850;
}

.widget-label-fixed {
    font-family: regular;
    font-size: 14px;
    color: #A07850;
    width: 60px;
}

/* Checkbox */

Checkbox {
    width: 18px;
    height: 18px;
    background-color: #1A1108;
    border-radius: 4px;
    border-width: 1.5px;
    border-color: #3D2812;
    color: #C8905A;
    transition: 150ms ease-out;
}

Checkbox:hover {
    background-color: #221608;
    border-color: #7A5030;
}

Checkbox:pressed {
    background-color: #160E05;
    border-color: #C8905A;
}

/* Slider */

Slider {
    height: 24px;
    width: grow;
    color: #C8905A;
}

/* TextInput */

.text-input {
    width: 100%;
    height: 34px;
    background-color: #1A1108;
    border-width: 1.5px;
    border-color: #3D2812;
    border-radius: 6px;
    color: #E8C898;
    font-family: regular;
    font-size: 14px;
    transition: 150ms ease-out;
}

.text-input:focus {
    background-color: #1F1508;
    border-color: #C8905A;
}

/* ColorPicker */

.color-picker {
    width: 100%;
    background-color: #1A1108;
    border-radius: 8px;
    border-width: 1px;
    border-color: #2A1F14;
    padding: 4px;
}

.cp-row {
    width: grow;
}

.cp-label {
    font-family: bold;
    font-size: 12px;
    color: #7A5030;
    width: 12px;
}

.cp-input {
    height: 26px;
    background-color: #140E06;
    border-width: 1px;
    border-color: #2A1F14;
    border-radius: 4px;
    color: #D0A878;
    font-family: regular;
    font-size: 13px;
}

.cp-input:focus {
    border-color: #C8905A;
}

/* ── Viewport ────────────────────────────────────────────────────────────── */

#viewport-area {
    flex-direction: column;
    flex-grow: 1;
    height: 100%;
}

#viewport {
    width: 100%;
    height: 100%;
    border-radius: 8px;
    border-width: 1px;
    border-color: #2A1F14;
}

Button {
    align-items: center;
    justify-content: center;
}
