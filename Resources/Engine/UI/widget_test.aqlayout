<View id="root">

    <View id="sidebar">

        <View id="brand">
            <Label id="brand-name">AQUILA</Label>
        </View>

        <View id="sidebar-divider"></View>

        <View id="nav">
            <Button id="btn-click" class="nav-btn">
                <Image src="Engine/UI/Icons/house.png" style="width: 16px; height: 16px;"/>
                Home
            </Button>
            <Button class="nav-btn">New Project</Button>
            <Button class="nav-btn">Open Project</Button>
            <Button class="nav-btn">Marketplace</Button>
            <Button class="nav-btn">Settings</Button>
        </View>

        <View id="version-area">
            <Label id="version-label">v 0.1.0-alpha</Label>
        </View>

    </View>

    <View id="main">

        <View id="main-header">
            <Label id="section-title">Recent Projects</Label>
        </View>

        <View id="projects-list">

            <Image id="viewport"/>

        </View>

    </View>

</View>
